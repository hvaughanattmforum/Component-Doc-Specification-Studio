node_modules/
# Everything under dist/ is a build artifact except the two packaged exes,
# which are tracked via Git LFS (see .gitattributes) so they can be
# distributed straight from the repo.
/dist/*
!/dist/ComponentDocSpecStudio.exe
!/dist/ComponentDocSpecStudio-Setup.exe
client/dist/
server/dist/
scripts/vendor/
scripts/__pycache__/
**/__pycache__/
installer/payload/*.exe
installer/payload/public.zip
installer/payload/scripts.zip
installer/payload/frameworks.zip
*.log
